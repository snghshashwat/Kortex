# App
APP_ENV=development
APP_PORT=8000

# Supabase Postgres (connection pooling URL recommended)
DATABASE_URL=postgresql://postgres:<password>@<host>:6543/postgres

# Telegram
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Optional auth secret. If omitted, the app falls back to TELEGRAM_WEBHOOK_SECRET.
AUTH_SECRET=replace_with_random_secret

# Google OAuth for personal calendar sync.
FRONTEND_BASE_URL=https://your-vercel-app.vercel.app
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# AI provider (using Groq via OpenAI-compatible endpoint)
LLM_API_KEY=your_groq_api_key
LLM_BASE_URL=https://api.groq.com/openai/v1
EMBEDDING_MODEL=llama3-70b-8192
OPTIONAL_CLEANING_MODEL=llama3-8b-8192
