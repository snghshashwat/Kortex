# App
APP_ENV=development
APP_PORT=8000

# Supabase Postgres (connection pooling URL recommended)
DATABASE_URL=postgresql://postgres:<password>@<host>:6543/postgres

# Telegram
TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
PUBLIC_BASE_URL=https://your-render-service.onrender.com

# Optional auth secret. If omitted, the app falls back to TELEGRAM_WEBHOOK_SECRET.
AUTH_SECRET=replace_with_random_secret

# Optional Google Calendar sync for reminders.
# If enabled, Kortex creates a Google Calendar event whenever a reminder is saved.
GOOGLE_CALENDAR_SYNC_REMINDERS=false
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
# Provide either GOOGLE_SERVICE_ACCOUNT_JSON or GOOGLE_SERVICE_ACCOUNT_FILE.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json

# AI provider (using Gemini via OpenAI-compatible endpoint)
LLM_API_KEY=your_gemini_api_key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
EMBEDDING_MODEL=text-embedding-004
OPTIONAL_CLEANING_MODEL=gemini-2.0-flash-lite
